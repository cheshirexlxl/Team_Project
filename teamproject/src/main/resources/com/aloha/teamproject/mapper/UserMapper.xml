<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aloha.teamproject.mapper.UserMapper">

	<resultMap id="userMap" type="Users">
		<id property="id" column="id" />
		<result property="username" column="username" />
		<result property="profileImg" column="profile_img" />
		<result property="password" column="password" />
		<result property="name" column="name" />
		<result property="nickname" column="nickname" />
		<result property="profileImg" column="profile_img" />
		<result property="status" column="status" />
		<result property="createdAt" column="created_at" />
		<result property="updatedAt" column="updated_at" />
		<collection property="authList"
					ofType="UserAuth"
					select="selectAuth"
					column="id">
		</collection>
	</resultMap>

	<resultMap id="authMap" type="UserAuth">
		<id property="no" column="no" />
		<result property="id" column="id" />
		<result property="userId" column="user_id" />
		<result property="auth" column="auth" />
		<result property="createdAt" column="created_at" />
		<result property="updatedAt" column="updated_at" />
	</resultMap>

	<insert id="join"> 
		INSERT INTO users ( id, username, password, name, nickname )
		VALUES ( #{id}, #{username}, #{password}, #{name}, #{nickname} )
    </insert>

	<insert id="insertAuth">
        INSERT INTO user_auth ( id, user_id, auth ) 
        VALUES ( #{id}, #{userId}, #{auth} )
    </insert>

	<delete id="deleteAuth">
		DELETE FROM user_auth
		WHERE user_id = #{userId}
		  AND auth = #{auth}
	</delete>
	
	<select id="list" resultMap="userMap"> 
		SELECT *
		FROM users
		ORDER BY created_at DESC
	</select>

	<select id="selectById" resultMap="userMap"> 
		SELECT *
		FROM users
		WHERE id = #{id}
	</select>

	<select id="selectByUsername" resultMap="userMap"> 
		SELECT *
		FROM users
		WHERE username = #{username}
	</select>

	<select id="selectByNickname" resultMap="userMap"> 
		SELECT *
		FROM users
		WHERE nickname = #{nickname}
	</select>

	<select id="selectAuth" resultMap="authMap">
		SELECT *
		FROM user_auth
		WHERE user_id = #{id}
	</select>

	<update id="update" parameterType="Users">
		UPDATE users
		SET
			username = #{username},
			name = #{name},
			nickname = #{nickname},
			status = #{status},
			<if test="password != null">
				password = #{password},
			</if>
			<if test="profileImg != null">
				profile_img = #{profileImg},
			</if>
			updated_at = NOW()
		WHERE no = #{no}
	</update>

	<update id="updateProfileImg">
		UPDATE users
		SET profile_img = #{profileImg},
			updated_at = NOW()
		WHERE id = #{userId}
	</update>

	<delete id="delete">
		DELETE FROM users
		WHERE no = #{no}
	</delete>

</mapper>
