<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aloha.teamproject.mapper.PaymentMapper">

    <resultMap id="PaymentMap" type="com.aloha.teamproject.dto.Payment">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="bookingId" column="booking_id"/>
        <result property="amount" column="amount"/>
        <result property="provider" column="provider"/>
        <result property="status" column="status"/>
        <result property="paidAt" column="paid_at"/>
    </resultMap>

    <select id="selectAll" resultMap="PaymentMap">
        SELECT * FROM payment
        ORDER BY created_at DESC
    </select>

    <select id="selectById" resultMap="PaymentMap">
        SELECT * FROM payment
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="PaymentMap">
        SELECT * FROM payment
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByBookingId" resultMap="PaymentMap">
        SELECT * FROM payment
        WHERE booking_id = #{bookingId}
    </select>

    <insert id="insert">
        INSERT INTO payment (
            id, user_id, booking_id, amount, provider, status, paid_at
        ) VALUES (
            UUID(), #{userId}, #{bookingId}, #{amount}, #{provider}, #{status}, #{paidAt}
        )
    </insert>

    <update id="update">
        UPDATE payment
        SET status = #{status}, paid_at = #{paidAt}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM payment WHERE id = #{id}
    </delete>

</mapper>
